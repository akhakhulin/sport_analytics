GARMIN_EMAIL=your_email@example.com
GARMIN_PASSWORD=your_password

# Куда складывать OAuth-токены (чтобы не логиниться каждый раз)
GARMIN_TOKENS_DIR=./.garminconnect

# Путь к локальной БД (используется и как embedded replica для Turso)
DB_PATH=./data/garmin.db

# Сколько дней истории тянуть при первом запуске
INITIAL_HISTORY_DAYS=365

# --- Multi-tenant ---
# Уникальный ID атлета (короткий, без пробелов, латиница). Все его данные
# будут помечены этим ID. Тренер задаёт ID каждому атлету при выдаче проекта.
ATHLETE_ID=me

# IS_ADMIN=true → в дашборде доступен селектор любых атлетов.
# false (по умолчанию) → видишь только свои данные.
IS_ADMIN=false

# --- Turso (опционально) ---
# Если оба значения заданы — БД синхронизируется с Turso, иначе работаем чисто локально.
# URL берётся со страницы базы в Turso, формат: libsql://garmin-xxx.turso.io
TURSO_DATABASE_URL=
# Auth-токен — кнопка "Create Token" в настройках базы
TURSO_AUTH_TOKEN=

# --- Cloud sync (только у тренера, для admin-CLI и облачного воркера) ---
# Мастер-ключ для шифрования Garmin-кредов «облачных» атлетов в Turso.
# Сгенерировать: `python -m cloud_sync.admin init-key`
# В GitHub Actions Secrets лежит этот же ключ под именем CLOUD_MASTER_KEY.
CLOUD_MASTER_KEY=
