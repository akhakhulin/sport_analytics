analysis_temp/

# Локальные настройки Claude Code (permissions)
.claude/

# Junction к external knowledge (на машине пользователя)
knowledge/external/

# Whisper-транскрипты и промежуточные audio/frames (восстановимо)
video_analysis/

# === BeatMetrics infra (prod 2026-05) ===

# TLS-сертификаты — приватный ключ НИКОГДА не должен попасть в git
beatmetrics/certs/

# nginx — коммитим только conf/, start_nginx.bat и наш landing (html/ + assets).
# Бинарник nginx.exe и дистрибутив (docs/contrib/modules) ставятся локально.
beatmetrics/nginx/*
!beatmetrics/nginx/conf/
!beatmetrics/nginx/start_nginx.bat
!beatmetrics/nginx/html/
beatmetrics/nginx/html/*
!beatmetrics/nginx/html/landing.html
!beatmetrics/nginx/html/landing-assets/
!beatmetrics/nginx/html/landing-assets/**

# Бинарники third-party (большие, ставятся локально на каждой машине)
tools/cloudflared.exe
tools/winacme/
tools/nginx/

# Бэкапы перед миграциями (snapshot, не для репо)
*.bak
*.bak-*
*-pre-brand-*

# Скриншоты онбординга/аудита — рабочие артефакты разработки
docs/screenshots/
